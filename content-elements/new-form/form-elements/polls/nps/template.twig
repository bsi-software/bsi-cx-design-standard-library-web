{#
    Parameter Header
    Fallback order: explicit parameter -> properties.* -> default value.

    formFieldElementId: Root data-bsi-element ID for the NPS poll.
    formFieldElementPartId: data-bsi-element-part ID for the poll wrapper.
    formFieldHelperTextPartId: data-bsi-element-part ID for helper text.
    formFieldErrorInvalidPartId: data-bsi-element-part ID for invalid feedback.
    formFieldLeftLabelPartId: data-bsi-element-part ID for left scale label.
    formFieldRightLabelPartId: data-bsi-element-part ID for right scale label.
    formFieldLabelText: Main poll label text.
    formFieldLeftLabelText: Left-side scale label text.
    formFieldRightLabelText: Right-side scale label text.
    formFieldHelperText: Optional helper text below the poll.
    customClasses: Additional CSS classes for the root wrapper.

    pollMin: Minimum selectable value (0 when npsStartWithZero/properties.npsStartWithZero is true, otherwise 1).
    pollMax: Maximum selectable value.
    pollRange: Iteration range used to render NPS options.
#}

{% set formFieldElementId = elementId ?: 'form-poll-nps-a026d07b' %}
{% set formFieldElementPartId = elementPartId ?: 'form-poll-nps-part-0f3d03c5' %}
{% set formFieldHelperTextPartId = formHelperTextPartId ?: 'form-poll-nps-helper-text-part-18d96c98' %}
{% set formFieldErrorInvalidPartId = errorInvalidPartId ?: 'form-poll-nps-part-error-invalid-8fbaf46c' %}
{% set formFieldLeftLabelPartId = leftLabelPartId ?: 'left-label-nps-part-210cf3a6' %}
{% set formFieldRightLabelPartId = rightLabelPartId ?: 'right-label-nps-part-312d8b6e' %}
{% set formFieldLabelText = labelText ?: bsi_cx_lorem(3) %}
{% set formFieldLeftLabelText = leftLabelText ?: bsi_cx_lorem(3) %}
{% set formFieldRightLabelText = rightLabelText ?: bsi_cx_lorem(3) %}
{% set formFieldHelperText = infoText ?: "" %}
{% set customClasses = customClasses ?: "" %}

{% set pollMin = (npsStartWithZero or properties.npsStartWithZero) ? 0 : 1 %}
{% set pollMax = 10 %}
{% set pollRange = range(pollMin, pollMax) %}


<div
    data-bsi-element="{{ formFieldElementId }}" class="bsi-element-{{ formFieldElementId }} form-element {{ customClasses }}"
    data-bsi-element-part="{{ formFieldElementPartId }}" data-bsi-value-list="{% for i in pollRange %}{{ i ~ '\n' }}{% endfor %}" id="nps-poll">
    <label class="form-label">{{ formFieldLabelText }}</label>
    <div class="form-field-layout">
        <div class="nps-container form-field-input-wrapper">
            <div class="scale-label-wrapper">
                <fieldset class="nps-preview nps-radio-group" data-bsi-radio-group="" role="radiogroup">
                    {% for value in pollRange %}
                        {% block npsTemplate %}
                            <div class="nps-item" data-bsi-radio-item="">
                                <input @change="formElementValidationOnChange" class="native-nps-input native-input" type="radio" id="nps-poll-{{ value }}" value="{{ value }}" name="nps-poll"/>
                                <label class="visual-nps-input visual-input" for="nps-poll">{{ value }}</label>
                            </div>
                        {% endblock %}
                    {% endfor %}
                </fieldset>
                <div class="nps-scale-labels">
                    <label data-bsi-element-part="{{ formFieldLeftLabelPartId }}" class="left-nps-scale-label second-form-label">{{ formFieldLeftLabelText }}</label>
                    <label data-bsi-element-part="{{ formFieldRightLabelPartId }}" class="right-nps-scale-label second-form-label">{{ formFieldRightLabelText }}</label>
                </div>
            </div>
        </div>
        <div class="form-field-feedback-wrapper">
            {% block poll_feedback %}
                <div class="bsi-invalid-feedback"></div> {# for error messages from formular #}
            {% endblock %}
        </div>
        <div class="helper-text-container">
            <div data-bsi-element-part="{{ formFieldHelperTextPartId }}" class="helper-text">{{ formFieldHelperText }}</div>
        </div>
    </div>
</div>