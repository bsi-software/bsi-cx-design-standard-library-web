{#
    Parameter Header
    Fallback order: explicit parameter -> default value.

    formFieldElementId: Root data-bsi-element ID for the star poll.
    formFieldElementPartId: data-bsi-element-part ID for the poll wrapper.
    formFieldHelperTextPartId: data-bsi-element-part ID for helper text.
    formFieldErrorInvalidPartId: data-bsi-element-part ID for invalid feedback.
    formFieldLabelText: Main poll label text.
    formFieldLeftLabelText: Left-side scale label text.
    formFieldRightLabelText: Right-side scale label text.
    formFieldHelperText: Optional helper text below the poll.
    customClasses: Additional CSS classes for the root wrapper.

    pollMin: Minimum selectable value.
    pollMax: Maximum selectable value.
    pollStep: Increment step for numeric value.
    pollRange: Iteration range used to render star options.
    pollValueList: Newline-separated value list derived from pollRange.
#}

{% set formFieldElementId = elementId ?: 'form-poll-star-2c7c0910' %}
{% set formFieldElementPartId = elementPartId ?: 'form-poll-star-part-7abccf42' %}
{% set formFieldHelperTextPartId = formHelperTextPartId ?: 'form-poll-star-helper-text-part-3ecf0459' %}
{% set formFieldErrorInvalidPartId = errorInvalidPartId ?: 'form-poll-star-part-error-invalid-5e251558' %}
{% set formFieldLabelText = labelText ?: bsi_cx_lorem(3) %}
{% set formFieldLeftLabelText = leftLabelText ?: bsi_cx_lorem(3) %}
{% set formFieldRightLabelText = rightLabelText ?: bsi_cx_lorem(3) %}
{% set formFieldHelperText = infoText ?: "" %}
{% set customClasses = customClasses ?: "" %}

{% set pollMin = 1 %}
{% set pollMax = 5 %}
{% set pollStep = 1 %}
{% set pollRange = range(pollMin, pollMax)%}
{% set pollValueList = '' %}
{% for value in pollRange %}
	{% set pollValueList = pollValueList ~ value ~ (loop.last == false ? "\n" : '') %}
{% endfor %}

<div x-data="starPoll" data-bsi-element="{{ formFieldElementId }}" class="bsi-element-{{ formFieldElementId }} form-element {{ customClasses }}" data-bsi-element-part="{{ formFieldElementPartId }}" data-bsi-form-field-fixed-type="number">
    <label class="form-label">{{ formFieldLabelText }}</label>
    <div class="form-field-layout">
        <div class="form-field-input-wrapper">
            <div class="star-container">
                <input
                    id="number-field"
                    name="star-poll-input"
                    type="number"
                    class="number-input"
                    min="{{ pollMin }}",
                    max="{{ pollMax }}",
                    step="{{ pollStep }}",
                    value="",
                >
                </input>
                <div x-init="initStar" class="star-preview nps-radio-group" role="radiogroup">
                    {% for value in pollRange %}
                        <div class="star-item" data-bsi-remove-if="live">
                            <input class="native-star-input native-input" type="radio" id="poll-input-{{ value }}" value="{{ value }}"/>
                            <span class="visual-star-input" for="poll-input-{{ value }}"></span>
                        </div>
                    {% endfor %}
                </div>
                <div class="star-rating-fill">
                    <label class="star-rating-fill-label"></label>
                </div>
            </div>
        </div>
        <div class="form-field-feedback-wrapper">
            {% block stars_feedback %}
                <div class="bsi-invalid-feedback"></div> {# for error messages from formular #}
            {% endblock %}
        </div>
        <div class="helper-text-container">
            <div data-bsi-element-part="{{ formFieldHelperTextPartId }}" class="helper-text">{{ formFieldHelperText }}</div>
        </div>
    </div>
</div>