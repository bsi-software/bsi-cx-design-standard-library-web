{% apply spaceless %}
    {% set formTextareaElementId = elementId ?: 'textarea-a4af575b' %}
    {% set formTextareaElementPartId = elementPartId ?: 'textarea-part-18ad4cb0' %}
    {% set formTextareaHelperTextPartId = formTextareaHelperTextPartId ?: 'textarea-helper-text-part-47792922' %}
    {% set formFieldShowMaxLengthCounter = showMaxLengthCounter ?: 'bsi-show-max-length-counter' %} {# Optionen: 'bsi-show-max-length-counter' or 'bsi-hide-max-length-counter' #}
    {% set formTextareaErrorInvalidPartId = errorInvalidPartId ?: 'textarea-error-invalid-part-52eb82f6' %}
    {% set formTextareaLabelText = labelText ?: bsi_cx_lorem(3) %}
    {% set formTextareaHelperText = infoText  ?: "" %}
    {% set customClasses = customClasses ?: "" %}

    <div data-bsi-element="{{ formTextareaElementId }}" class="bsi-element-{{ formTextareaElementId }} {{ formFieldShowMaxLengthCounter }} form-element {{ customClasses }}" data-bsi-element-part="{{ formTextareaElementPartId }}">
        <label for="textarea-element" class="form-label">{{ formTextareaLabelText }}</label>
        <div class="textarea-container form-field-layout">
            <div class="textarea-and-error-text form-field-input-wrapper">
                <textarea @change="formElementValidationOnChange" @blur="formElementValidationOnBlur" @input="formElementValidationOnInput" class="textarea-input" id="textarea-element" rows="5" value=""></textarea>
            </div>
            <div class="form-field-feedback-wrapper">
                {% block textarea_error_texts %}
                    <div class="bsi-invalid-feedback"></div> {# for error messages from formular #}
                {% endblock %}
            </div>
            <div class="max-char-counter"></div>
            <div class="helper-text-container">
                <div class="helper-text" data-bsi-element-part="{{ formTextareaHelperTextPartId }}">{{ formTextareaHelperText }}</div>
            </div>
        </div>
    </div>
{% endapply %}