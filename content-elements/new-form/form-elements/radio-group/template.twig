{% apply spaceless %}
    {% set formRadioGroupElementId = elementId ?: 'radio-group-6e279f5e' %}
    {% set formRadioGroupElementPartId = elementPartId ?: 'radio-group-label-84ad37f1' %}
    {% set formRadioGroupAlignment = alignment ?: 'form-group-alignment-vertical' %} {# alternative 'form-group-alignment-horizontal' #}
    {% set formRadioGroupLabel = groupLabel ?: 'Radio Button Gruppe' %}
    {% set formRadioGroupHelperTextPartId = formRadioGroupHelperTextPartId ?: 'radio-group-helper-text-part-c034d086' %}
    {% set formRadioGroupErrorInvalidPartId = errorInvalidPartId ?: 'radio-group-error-invalid-part-67e4dde8' %}
    {% set formRadioButtonLabelText = labelText ?: bsi_cx_lorem(3) %}
    {% set formRadioGroupHelperText = infoText ?: "" %}
    {% set customClasses = customClasses ?: "" %}

    {% set uniqueIdForAriaDescribedBy = 'helper-id-' ~ random() %}

    <div data-bsi-element="{{ formRadioGroupElementId }}" class="bsi-element-{{ formRadioGroupElementId }} form-element form-field radio-group {{ formRadioGroupAlignment }} {{ customClasses }}" data-bsi-element-part="{{ formRadioGroupElementPartId }}">
        <label class="form-label">{{ formRadioGroupLabel }}</label>
        <div class="input-field-container form-field-layout">
            <div class="input-field-with-error-text form-field-input-wrapper">
                <div data-bsi-radio-group="" class="radio-button-group">
                    <div class="radiobutton-with-label" data-bsi-radio-item="" role="radiogroup">
                        <input 
                            @change="formGroupValidationOnChange"
                            id="radio-element"
                            type="radio"
                            class="native-radio native-input"
                            aria-describedby="{{ uniqueIdForAriaDescribedBy }}">
                        </input>
                        <span 
                            @click="toggle"
                            class="visual-radio visual-input">
                        </span>
                        <label for="radio-element" class="second-form-label group-radio-label">{{ formRadioButtonLabelText }}</label>  
                    </div>
                    <div class="radiobutton-with-label" data-bsi-radio-item="" role="radiogroup">
                        <input 
                            @change="formGroupValidationOnChange"
                            id="radio-element-2"
                            type="radio"
                            class="native-radio native-input"
                            required
                            aria-describedby="{{ uniqueIdForAriaDescribedBy }}">
                        </input>
                        <span 
                            @click="toggle"
                            class="visual-radio visual-input">
                        </span>
                        <label for="radio-element-2" class="second-form-label group-radio-label">{{ formRadioButtonLabelText }}</label>  
                    </div>
                </div>
            </div>
            <div class="form-field-feedback-wrapper">
                {% block radio_info_and_error_texts %}
                    <div class="bsi-invalid-feedback"></div> {# for error messages from formular #}
                {% endblock %}
            </div>
            <div class="helper-text-container">
                <div data-bsi-element-part="{{ formRadioGroupHelperTextPartId }}" class="helper-text" id="{{ uniqueIdForAriaDescribedBy }}">{{ formRadioGroupHelperText }}</div>
            </div>
        </div>
    </div>
{% endapply %}