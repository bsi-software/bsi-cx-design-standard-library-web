{% set formFieldElementId = elementId ?: 'upload-form-field-5674018a' %}
{% set formFieldElementPartId = elementPartId ?: 'form-field-part-c21742af' %}
{% set formFieldHelperTextPartId = formHelperTextPartId ?: 'form-field-helper-text-part-0a34ce3d' %}
{% set formFieldErrorInvalidPartId = errorInvalidPartId ?: 'form-field-part-error-invalid-6ca6d1fd' %}
{% set formFieldLabelText = labelText ?: bsi_cx_lorem(3) %}
{% set formFieldHelperText = infoText ?: "" %}
{% set formFieldErrorInvalidText = errorInvalidText ?: 'Der Wert, den Sie für dieses Feld eingegeben haben, ist ungültig.' %}
{% set customClasses = customClasses ?: "" %}

<div x-data="fileUpload" data-bsi-element="{{ formFieldElementId }}" class="bsi-element-{{ formFieldElementId }} form-element form-field {{ customClasses }}" data-bsi-element-part="{{ formFieldElementPartId }}" data-bsi-form-field-fixed-type="{{ formFieldInputType }}">
    <label for="file-upload-field" class="form-label">{{ formFieldLabelText }}</label>
    <div 
        class="file-upload-container"
        @dragover.prevent="onDragOver"
        @dragleave.prevent="onDragLeave"
        @drop.prevent="onDrop"
    >
        <div class="file-upload-and-error-text">
            <div
                class="file-upload"
                x-cloak
            >
                {% block input_field %}
                    <input
                        @change="onFileChange"
                        @change-after-drop="onFileChangeAfterDrop"
                        @after-change="formElementValidationOnChange"
                        id="file-upload-field"
                        type="file"
                        x-ref="fileInput"
                        class="native-file-upload-input hidden"
                    >
                    </input>

                    <div class="left">
                        <button
                            type="button"
                            class="upload-button"
                            @click="triggerFileUpload"
                            x-show="noFiles"
                            aria-label="Datei auswählen"
                        >
                            <span>Datei auswählen</span> {# TODO: muss noch übersetzt werden #}
                            <i class="icon-upload"></i>
                        </button>
                        <div
                            class="file-info"
                            aria-live="polite"
                            x-show="hasFiles"
                        >
                            <img 
                                class="preview-image "
                                x-show="hasPreview"
                                :src="filePreview"
                                :alt="fileName"
                            />
                            <div class="file-text-wrapper">
                                <span class="second-form-label file-name" x-text="fileName"></span>
                                <span class="second-form-label file-suffix" x-text="fileSuffix"></span>
                                <span class="second-form-label file-size" x-text="fileSize"></span>
                            </div>
                        </div>
                    </div>

                    <div class="right">
                        <label
                            class="drop-text second-form-label"
                            aria-hidden="true"
                            x-show="noFiles"
                        > oder hier ablegen </label> {# TODO: muss noch übersetzt werden #}

                        <button
                            type="button"
                            class="remove-button"
                            aria-label="Datei entfernen"
                            @click="removeFile"
                            x-show="hasFiles"
                        >
                            <i class="icon-delete"></i>
                        </button>
                    </div>
                {% endblock %}
            </div>

            {% block input_field_error_text %}
                <div data-bsi-element-part="{{ formFieldErrorInvalidPartId }}" class="bsi-invalid-feedback">
                    {{ formFieldErrorInvalidText }}
                </div>
            {% endblock %}
        </div>
        
        <div class="helper-text-container">
            <div data-bsi-element-part="{{ formFieldHelperTextPartId }}" class="helper-text">{{ formFieldHelperText }}</div>
        </div>
    </div>
</div>
