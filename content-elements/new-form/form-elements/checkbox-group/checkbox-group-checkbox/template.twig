{% apply spaceless %}
    {#
        Parameter Header
        Fallback order: explicit parameter -> default value.

        formCheckboxElementId: Root data-bsi-element ID for the checkbox item.
        formCheckboxElementPartId: data-bsi-element-part ID for the checkbox wrapper.
        formCheckboxLabelText: Label text shown next to the checkbox.
        customClasses: Additional CSS classes for the root wrapper.
    #}
    {% set formCheckboxElementId = elementId ?: 'checkbox-group-checkbox-b2745977' %}
    {% set formCheckboxElementPartId = elementPartId ?: 'checkbox-group-checkbox-part-6cee4307' %}
    {% set formCheckboxLabelText = labelText ?: bsi_cx_lorem(3) %}
    {% set customClasses = customClasses ?: "" %}
    
    <div data-bsi-element="{{ formCheckboxElementId }}" class="bsi-element-{{ formCheckboxElementId }} {{ customClasses }}" data-bsi-element-part="{{ formCheckboxElementPartId }}" data-bsi-hide-required>
        <div class="checkbox-container">
            <div class="checkbox-with-label">
                <input @change="formGroupValidationOnChange" id="checkbox-element" type="checkbox" class="native-checkbox native-input checkbox-in-group"></input>
                <span class="visual-checkbox visual-input"></span>
                <label for="checkbox-element" class="second-form-label">{{ formCheckboxLabelText }}</label>  
            </div>
        </div>
    </div>
{% endapply %}