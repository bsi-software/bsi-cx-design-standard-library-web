{% set formFieldElementId = elementId ?: 'form-field-2217aee4' %}
{% set formFieldElementPartId = elementPartId ?: 'form-field-part-740b4e74' %}
{% set formFieldHelperTextPartId = formHelperTextPartId ?: 'form-field-helper-text-part-fb1cdc8d' %}
{% set formFieldShowMaxLengthCounter = showMaxLengthCounter ?: 'bsi-hide-max-length-counter' %} {# Optionen: 'bsi-show-max-length-counter' or 'bsi-hide-max-length-counter' #}
{% set formFieldLabelText = labelText ?: bsi_cx_lorem(3) %}
{% set formFieldHelperText = infoText ?: "" %}
{% set formFieldInputType = inputType ?: "text" %}
{% set customClasses = customClasses ?: "" %}

<div data-bsi-element="{{ formFieldElementId }}" class="bsi-element-{{ formFieldElementId }} {{ formFieldShowMaxLengthCounter }} form-element {{ customClasses }}" data-bsi-element-part="{{ formFieldElementPartId }}" data-bsi-form-field-fixed-type="{{ formFieldInputType }}">
    <label for="{{ formFieldInputType }}-field" class="form-label">{{ formFieldLabelText }}</label>
    <div class="form-field-layout">
        <div class="form-field-input-wrapper">
            {% block input_field %}
                <input
                    @change="formElementValidationOnChange"
                    @blur="formElementValidationOnBlur"
                    @input="formElementValidationOnInput"
                    id="{{ formFieldInputType }}-field"
                    type="{{ formFieldInputType }}"
                    class="{{ formFieldInputType }}-input"
                    maxlength="250"
                >
                </input>
            {% endblock %}
        </div>
        <div class="form-field-feedback-wrapper">
            {% block input_field_error_text %}
                <div class="bsi-invalid-feedback"></div> {# for error messages from formular #}
            {% endblock %}
        </div>
        <div class="max-char-counter"></div>
        <div class="helper-text-container">
            <div data-bsi-element-part="{{ formFieldHelperTextPartId }}" class="helper-text">{{ formFieldHelperText }}</div>
        </div>
    </div>
</div>