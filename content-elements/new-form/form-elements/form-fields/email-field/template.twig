{# It's not possible to embed this file somewhere else because it is embeded it's self.
Please use form-field-prototype.twig instead #}

{#
    Parameter Header
    Fallback order: explicit parameter -> properties.* -> default value.

    formFieldErrorInvalidPartId: data-bsi-element-part ID for the email invalid feedback.
    formFieldErrorInvalidText: Email-specific invalid text (properties.emailInvalidText fallback).
#}

{% set formFieldErrorInvalidPartId = 'form-field-part-error-invalid-21769f4a' %}
{% set formFieldErrorInvalidText = properties.emailInvalidText ?: 'Sie haben keine gültige E-Mail Adresse eingegeben. Beispiel: mail@example.com' %}

{% apply spaceless %}
    {% embed "../_prototype/form-field-prototype.twig" with {
        elementId: 'form-field-bdcd8d55',
        elementPartId: 'form-field-part-71d76c77',
        formHelperTextPartId: 'form-field-part-email-033f20a1',
        labelText: "E-Mail Feld",
        infoText: "",
        inputType: "email",
    } %}
        {% block input_field_error_text %}
            {# for error messages from formular and error message from this field for pattern missmatch #}
            <div data-bsi-element-part="{{ formFieldErrorInvalidPartId }}" class="bsi-invalid-feedback">
                {{ formFieldErrorInvalidText }}
            </div>
        {% endblock %}
    {% endembed %}
{% endapply %}